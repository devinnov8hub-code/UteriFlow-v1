# Copy this file to `.env` and fill in the values.
#
# VITE_API_URL — the backend API base URL.
# MUST include /api/v1 at the end. If you forget it, the code will try to
# auto-append it for you, but it's clearer to set the full URL explicitly.
#
# Local backend:
VITE_API_URL=http://localhost:3000/api/v1
#
# Production (uncomment to use):
# VITE_API_URL=https://uteri-flow-v1.vercel.app/api/v1

# VITE_FORM_ID — the Forminit form ID for the waitlist email-capture form.
# Get this from your Forminit dashboard.
VITE_FORM_ID=your_forminit_form_id_here
