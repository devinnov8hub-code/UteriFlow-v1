# Copy this file to `.env` and fill in the values.
#
# VITE_API_URL — the backend API base URL.
# MUST include /api/v1 at the end. The code auto-appends it if you forget,
# but it's clearer to set the full URL explicitly.

# Local backend:
VITE_API_URL=http://localhost:3000/api/v1
#
# Production (set in Vercel env vars instead):
# VITE_API_URL=https://uteri-flow-v1.vercel.app/api/v1

# VITE_FORM_ID — Forminit form ID for the waitlist email-capture form.
VITE_FORM_ID=your_forminit_form_id_here
